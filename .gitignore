# Credentials & settings (saved via the UI — never commit these)
config/
.env
.env.local
.env.*.local
backend/.env
backend/.env.local
backend/.env.*.local
backend/settings.json

# User annotations — personal data, never commit
backend/notes.json
backend/rg_descriptions.json
backend/action_statuses.json
backend/company_name.txt
# User-supplied report logo — place logo.png/jpg/svg here to brand PDF exports
backend/logo.png
backend/logo.jpg
backend/logo.jpeg
backend/logo.svg

# Private keys & certificates — never commit
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt

# Python
backend/.venv/
backend/__pycache__/
**/__pycache__/
*.pyc
*.pyo

# Node
frontend/node_modules/
frontend/dist/

# Logs
*.log
logs/

# Screenshots and internal session images (exclude root-level dev screenshots)
image*.png
Screenshot*.png
*screenshot*.png
# But allow docs/screenshots/ for README assets
!docs/screenshots/*.png

# Company-specific logo (never commit — use Settings > Branding to upload your own)
frontend/src/assets/impax-logo.png

# Internal development notes (backlog, session history)
IMPROVEMENTS.md

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/
